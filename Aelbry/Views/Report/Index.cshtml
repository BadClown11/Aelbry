@{
    ViewData["Title"] = "Reportes & KPIs";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Reportes & KPIs</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="Reports.exportReport('Excel')">Exportar Excel</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="Reports.exportReport('Word')">Exportar Word</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="Reports.exportReport('Pdf')">Exportar PDF</button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-0">ID de empresa</label>
                <input type="number" class="form-control form-control-sm" id="filterCompanyId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Proyecto (opcional)</label>
                <input type="number" class="form-control form-control-sm" id="filterProjectId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Empleado (opcional)</label>
                <input type="number" class="form-control form-control-sm" id="filterUserId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Equipo (opcional)</label>
                <input type="number" class="form-control form-control-sm" id="filterTeamId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Departamento (opcional)</label>
                <input type="number" class="form-control form-control-sm" id="filterDepartmentId" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm w-100" onclick="Reports.loadAll()">Aplicar filtros</button>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabWeekly">Reporte Semanal</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabKpis">KPIs</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCharts">Graficas</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabBurndown">Burndown</button></li>
</ul>

<div class="tab-content">
    <!-- REPORTE SEMANAL -->
    <div class="tab-pane fade show active" id="tabWeekly">
        <div class="d-flex gap-2 mb-2">
            <div>
                <label class="form-label small mb-0">Vence desde</label>
                <input type="date" class="form-control form-control-sm" id="weeklyStartDate" />
            </div>
            <div>
                <label class="form-label small mb-0">Vence hasta</label>
                <input type="date" class="form-control form-control-sm" id="weeklyEndDate" />
            </div>
            <div class="align-self-end">
                <button class="btn btn-outline-secondary btn-sm" onclick="Reports.loadWeekly()">Buscar</button>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Codigo</th>
                            <th>Nombre</th>
                            <th>Proyecto</th>
                            <th>Responsable</th>
                            <th>Estado</th>
                            <th>Prioridad</th>
                            <th>Vence</th>
                            <th>Dias transc.</th>
                            <th>Dias rest.</th>
                            <th>Riesgo</th>
                        </tr>
                    </thead>
                    <tbody id="weeklyRows"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- KPIS -->
    <div class="tab-pane fade" id="tabKpis">
        <div class="mb-2">
            <label class="form-label small mb-0">Inicio de semana</label>
            <input type="date" class="form-control form-control-sm" id="kpiWeekStart" style="width: 200px" onchange="Reports.loadKpis()" />
        </div>
        <div class="row g-3" id="kpiCards"></div>
    </div>

    <!-- GRAFICAS -->
    <div class="tab-pane fade" id="tabCharts">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card"><div class="card-body"><h6>Avance promedio por empleado</h6><canvas id="progressByUserChart"></canvas></div></div>
            </div>
            <div class="col-md-6">
                <div class="card"><div class="card-body"><h6>Distribucion por prioridad</h6><canvas id="priorityChart"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- BURNDOWN -->
    <div class="tab-pane fade" id="tabBurndown">
        <div class="d-flex gap-2 mb-2">
            <div>
                <label class="form-label small mb-0">Desde</label>
                <input type="date" class="form-control form-control-sm" id="burndownStartDate" />
            </div>
            <div>
                <label class="form-label small mb-0">Hasta</label>
                <input type="date" class="form-control form-control-sm" id="burndownEndDate" />
            </div>
            <div class="align-self-end">
                <button class="btn btn-outline-secondary btn-sm" onclick="Reports.loadBurndown()">Generar (requiere Proyecto en los filtros)</button>
            </div>
        </div>
        <div class="card"><div class="card-body"><canvas id="burndownChart"></canvas></div></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/reports.js"></script>
}
