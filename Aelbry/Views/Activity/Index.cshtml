@{
    ViewData["Title"] = "Actividades";
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0">Actividades (WBS)</h4>
    <div class="d-flex gap-2">
        <input type="hidden" id="filterProjectId" />
        <input type="search" id="filterActivityName" class="form-control form-control-sm" placeholder="Buscar por nombre..." style="width: 220px" oninput="Activities.applyFilters()" />
        <select id="filterResponsibleId" class="form-select form-select-sm" style="width: 190px" onchange="Activities.applyFilters()">
            <option value="">Todos los responsables</option>
        </select>
        <button class="btn btn-aelbry-new btn-sm" onclick="Activities.openCreate(null)">
            <span class="btn-aelbry-new__icon">+</span> Nueva actividad raiz
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table align-middle mb-0" id="activityTable">
            <thead>
                <tr>
                    <th class="ps-3">Codigo</th>
                    <th>Nombre</th>
                    <th>Estado</th>
                    <th>Prioridad</th>
                    <th>Responsable</th>
                    <th class="text-center">Peso</th>
                    <th>Avance</th>
                    <th class="text-end pe-3"></th>
                </tr>
            </thead>
            <tbody id="activityRows"></tbody>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/activities.css" asp-append-version="true" />
}

<!-- Modal: Actividad -->
<div class="modal fade" id="activityModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activityModalTitle">Actividad</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="activityId" />
                <input type="hidden" id="activityParentId" />

                <div id="activityProgressBanner" class="d-none mb-4">
                    <div class="d-flex justify-content-between align-items-center small text-muted mb-1">
                        <span><i data-lucide="trending-up" style="width:14px;height:14px;"></i> Avance (automatico segun subactividades)</span>
                        <span class="fw-semibold" id="activityProgressLabel">0%</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        <div class="progress-bar bg-success" id="activityProgressBar" style="width:0%"></div>
                    </div>
                </div>

                <h6 class="text-uppercase text-muted small fw-bold mb-3">Informacion general</h6>
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" id="activityName" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color w-100" id="activityColor" value="#4C6EF5" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Peso</label>
                        <input type="number" step="0.01" class="form-control" id="activityWeight" value="1" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-control" id="activityDescription" rows="2"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Categoria</label>
                        <div class="input-group">
                            <select class="form-select" id="activityCategory">
                                <option value="">-- Sin categoria --</option>
                            </select>
                            <button class="btn btn-outline-secondary" type="button" title="Nueva categoria" onclick="Activities.promptNewCategory()">+</button>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Estado</label>
                        <select class="form-select" id="activityStatus">
                            <option value="1">Pendiente</option>
                            <option value="2">En Progreso</option>
                            <option value="3">Bloqueada</option>
                            <option value="4">Completada</option>
                            <option value="5">Cancelada</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Prioridad</label>
                        <select class="form-select" id="activityPriority">
                            <option value="1">Baja</option>
                            <option value="2" selected>Media</option>
                            <option value="3">Alta</option>
                            <option value="4">Critica</option>
                        </select>
                    </div>
                </div>

                <hr class="my-4" />
                <h6 class="text-uppercase text-muted small fw-bold mb-3">Responsable</h6>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <select class="form-select" id="activityResponsibleId">
                            <option value="">-- Selecciona un responsable --</option>
                        </select>
                    </div>
                </div>

                <hr class="my-4" />
                <h6 class="text-uppercase text-muted small fw-bold mb-3">Fechas</h6>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Estimada inicio</label>
                        <input type="date" class="form-control" id="activityEstStart" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Estimada fin</label>
                        <input type="date" class="form-control" id="activityEstEnd" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Real inicio</label>
                        <input type="date" class="form-control" id="activityActualStart" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Real fin</label>
                        <input type="date" class="form-control" id="activityActualEnd" />
                    </div>
                </div>

                <hr class="my-4" />
                <h6 class="text-uppercase text-muted small fw-bold mb-3">Horas</h6>
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Estimadas</label>
                        <input type="number" step="0.01" class="form-control" id="activityEstimatedHours" value="0" />
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Trabajadas</label>
                        <input type="number" step="0.01" class="form-control" id="activityWorkedHours" value="0" />
                    </div>
                </div>

                <div id="activitySubtasksSection" class="d-none">
                    <hr class="my-4" />
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Subactividades</h6>
                    <ul class="list-group mb-3" id="activitySubtaskRows"></ul>
                    <button type="button" class="btn btn-outline-primary btn-sm" id="activitySubtaskToggleBtn" onclick="Activities.toggleInlineSubtaskForm()">+ Agregar subactividad</button>

                    <div id="activityInlineSubtaskForm" class="d-none mt-3 p-3 border rounded bg-body-tertiary">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label small">Nombre</label>
                                <input class="form-control form-control-sm" id="subtaskName" />
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="form-label small">Categoria</label>
                                <select class="form-select form-select-sm" id="subtaskCategory">
                                    <option value="">-- Sin categoria --</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="form-label small">Peso</label>
                                <input type="number" step="0.01" class="form-control form-control-sm" id="subtaskWeight" value="1" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12 mb-2">
                                <label class="form-label small">Responsable</label>
                                <select class="form-select form-select-sm" id="subtaskResponsibleId">
                                    <option value="">-- Selecciona un responsable --</option>
                                </select>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <button class="btn btn-sm btn-secondary" onclick="Activities.toggleInlineSubtaskForm()">Cancelar</button>
                            <button class="btn btn-sm btn-primary" onclick="Activities.saveInlineSubtask()">Guardar subactividad</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Activities.save()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Checklist -->
<div class="modal fade" id="checklistModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Checklist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="checklistActivityId" />
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="newChecklistText" placeholder="Nuevo punto del checklist" />
                    <button class="btn btn-outline-primary" onclick="Activities.addChecklistItem()">Agregar</button>
                </div>
                <ul class="list-group" id="checklistRows"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Dependencias -->
<div class="modal fade" id="dependenciesModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dependencias (bloqueos)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="dependenciesActivityId" />
                <div class="row mb-3">
                    <div class="col-5">
                        <input type="number" class="form-control" id="newDependsOnActivityId" placeholder="ID actividad predecesora" />
                    </div>
                    <div class="col-5">
                        <select class="form-select" id="newDependencyType">
                            <option value="1">Fin a Inicio</option>
                            <option value="2">Inicio a Inicio</option>
                            <option value="3">Fin a Fin</option>
                            <option value="4">Inicio a Fin</option>
                        </select>
                    </div>
                    <div class="col-2">
                        <button class="btn btn-outline-primary w-100" onclick="Activities.addDependency()">+</button>
                    </div>
                </div>
                <ul class="list-group" id="dependencyRows"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Participantes -->
<div class="modal fade" id="participantsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Participantes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="participantsActivityId" />
                <div class="input-group mb-3">
                    <select class="form-select" id="newParticipantUserId">
                        <option value="">-- Selecciona una persona --</option>
                    </select>
                    <button class="btn btn-outline-primary" onclick="Activities.addParticipant()">Agregar</button>
                </div>
                <ul class="list-group" id="participantRows"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Tiempo -->
<div class="modal fade" id="timeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tiempo registrado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="timeActivityId" />
                <div class="mb-3" id="timeTimerControls"></div>
                <ul class="list-group" id="timeRows"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Etiquetas -->
<div class="modal fade" id="activityTagsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Etiquetas de la actividad</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="activityTagsActivityId" />
                <div id="activityTagsChecklist"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/activities.js" asp-append-version="true"></script>
}
