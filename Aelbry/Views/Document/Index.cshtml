@{
    ViewData["Title"] = "Documentos & Archivos";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Documentos & Archivos</h4>
    <div class="d-flex gap-2">
        <input type="number" id="filterProjectId" class="form-control form-control-sm" placeholder="ID de proyecto" style="width: 160px" />
        <button class="btn btn-outline-secondary btn-sm" onclick="DocFiles.loadAll()">Buscar</button>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabDocuments">Documentos</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabFiles">Archivos</button></li>
</ul>

<div class="tab-content">
    <!-- DOCUMENTOS -->
    <div class="tab-pane fade show active" id="tabDocuments">
        <div id="documentListView">
            <div class="d-flex justify-content-end mb-2">
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newDocumentModal">Nuevo documento</button>
            </div>
            <div class="card">
                <div class="card-body">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Titulo</th>
                                <th>Version actual</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody id="documentRows"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="documentEditorView" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" onclick="DocFiles.closeEditor()">&larr; Volver</button>
                    <input type="text" id="editorTitle" class="form-control form-control-sm" style="width: 320px" />
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" onclick="DocFiles.openHistory()">Historial</button>
                    <button class="btn btn-primary btn-sm" onclick="DocFiles.saveVersion()">Guardar nueva version</button>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-2">
                    <label class="form-label small text-muted">Markdown</label>
                    <textarea id="editorContent" class="form-control aelbry-scroll" style="height: 480px; font-family: monospace;" oninput="DocFiles.renderPreview()"></textarea>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label small text-muted">Vista previa</label>
                    <div id="editorPreview" class="card card-body aelbry-scroll" style="height: 480px;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ARCHIVOS -->
    <div class="tab-pane fade" id="tabFiles">
        <div class="card mb-3">
            <div class="card-body d-flex gap-3 flex-wrap align-items-end">
                <div>
                    <label class="form-label small mb-0">Carpeta</label>
                    <select class="form-select form-select-sm" id="filterFolderId" style="width: 220px" onchange="DocFiles.loadFiles()">
                        <option value="">Raiz</option>
                    </select>
                </div>
                <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#newFolderModal">Nueva carpeta</button>
                <label class="btn btn-primary btn-sm mb-0">
                    Subir archivo
                    <input type="file" id="uploadFileInput" class="d-none" onchange="DocFiles.uploadFile()" />
                </label>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Version</th>
                            <th>Tamaño</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody id="fileRows"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Nuevo documento -->
<div class="modal fade" id="newDocumentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo documento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Titulo</label>
                <input type="text" id="newDocumentTitle" class="form-control" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="DocFiles.createDocument()">Crear</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Nueva carpeta -->
<div class="modal fade" id="newFolderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nueva carpeta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Nombre</label>
                <input type="text" id="newFolderName" class="form-control" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="DocFiles.createFolder()">Crear</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Historial de versiones -->
<div class="modal fade" id="historyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de versiones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="list-group" id="historyRows"></ul>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/documents.css" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
    <script src="~/js/documents.js"></script>
}
