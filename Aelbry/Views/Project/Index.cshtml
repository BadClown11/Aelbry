@{
    ViewData["Title"] = "Proyectos";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Proyectos</h4>
    <div class="d-flex gap-2">
        <input type="number" id="filterCompanyId" class="form-control form-control-sm" placeholder="ID de empresa" style="width: 160px" />
        <button class="btn btn-outline-secondary btn-sm" onclick="Projects.loadAll()">Buscar</button>
    </div>
</div>

<ul class="nav nav-tabs mb-3" id="projectTabs">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabProjects">Proyectos</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabStatuses">Estados</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabTags">Etiquetas</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabTemplates">Plantillas</button></li>
</ul>

<div class="tab-content">
    <!-- PROYECTOS -->
    <div class="tab-pane fade show active" id="tabProjects">
        <div class="text-end mb-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#projectModal" onclick="Projects.openCreate()">Nuevo proyecto</button>
        </div>
        <div class="card">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Codigo</th>
                            <th>Nombre</th>
                            <th>Estado</th>
                            <th>Prioridad</th>
                            <th>Riesgo</th>
                            <th>Responsable</th>
                            <th>Avance</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="projectRows"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ESTADOS -->
    <div class="tab-pane fade" id="tabStatuses">
        <div class="text-end mb-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#statusModal" onclick="Projects.openCreateStatus()">Nuevo estado</button>
        </div>
        <div class="card">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Orden</th>
                            <th>Nombre</th>
                            <th>Color</th>
                            <th>Final</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="statusRows"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ETIQUETAS -->
    <div class="tab-pane fade" id="tabTags">
        <div class="text-end mb-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#tagModal" onclick="Projects.openCreateTag()">Nueva etiqueta</button>
        </div>
        <div class="card">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Color</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="tagRows"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- PLANTILLAS -->
    <div class="tab-pane fade" id="tabTemplates">
        <div class="text-end mb-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#templateModal" onclick="Projects.openCreateTemplate()">Nueva plantilla</button>
        </div>
        <div class="card">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripcion</th>
                            <th>Prioridad default</th>
                            <th>Horas est. default</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="templateRows"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Proyecto -->
<div class="modal fade" id="projectModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="projectId" />
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Codigo</label>
                        <input class="form-control" id="projectCode" />
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" id="projectName" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color" id="projectColor" value="#4C6EF5" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Cliente</label>
                        <input class="form-control" id="projectClient" />
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Responsable (ID de usuario)</label>
                        <input type="number" class="form-control" id="projectManagerId" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <label class="form-label">Estado</label>
                        <select class="form-select" id="projectStatusId"></select>
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label">Prioridad</label>
                        <select class="form-select" id="projectPriority">
                            <option value="1">Baja</option>
                            <option value="2" selected>Media</option>
                            <option value="3">Alta</option>
                            <option value="4">Critica</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label">Riesgo</label>
                        <select class="form-select" id="projectRiskLevel">
                            <option value="1" selected>Bajo</option>
                            <option value="2">Medio</option>
                            <option value="3">Alto</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Fecha inicio</label>
                        <input type="date" class="form-control" id="projectStartDate" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Fecha fin</label>
                        <input type="date" class="form-control" id="projectEndDate" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Presupuesto</label>
                        <input type="number" step="0.01" class="form-control" id="projectBudget" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Horas estimadas</label>
                        <input type="number" step="0.01" class="form-control" id="projectEstimatedHours" value="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Projects.save()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Miembros -->
<div class="modal fade" id="membersModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Miembros del proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="membersProjectId" />
                <div class="input-group mb-3">
                    <input type="number" class="form-control" id="newMemberUserId" placeholder="ID de usuario" />
                    <button class="btn btn-outline-primary" onclick="Projects.addMember()">Agregar</button>
                </div>
                <ul class="list-group" id="memberRows"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Etiquetas del proyecto -->
<div class="modal fade" id="projectTagsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Etiquetas del proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="projectTagsProjectId" />
                <div id="projectTagsChecklist"></div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Estado de proyecto -->
<div class="modal fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Estado de proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="statusId" />
                <div class="mb-2">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" id="statusName" />
                </div>
                <div class="row">
                    <div class="col mb-2">
                        <label class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color" id="statusColor" value="#6C757D" />
                    </div>
                    <div class="col mb-2">
                        <label class="form-label">Orden</label>
                        <input type="number" class="form-control" id="statusSequence" value="0" />
                    </div>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="statusIsFinal" />
                    <label class="form-check-label">Es un estado final (completado/cancelado)</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Projects.saveStatus()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Etiqueta (catalogo) -->
<div class="modal fade" id="tagModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Etiqueta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="tagId" />
                <div class="mb-2">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" id="tagName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Color</label>
                    <input type="color" class="form-control form-control-color" id="tagColor" value="#868E96" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Projects.saveTag()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Plantilla de proyecto -->
<div class="modal fade" id="templateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Plantilla de proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="templateId" />
                <div class="mb-2">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" id="templateName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-control" id="templateDescription"></textarea>
                </div>
                <div class="row">
                    <div class="col mb-2">
                        <label class="form-label">Prioridad default</label>
                        <select class="form-select" id="templateDefaultPriority">
                            <option value="1">Baja</option>
                            <option value="2" selected>Media</option>
                            <option value="3">Alta</option>
                            <option value="4">Critica</option>
                        </select>
                    </div>
                    <div class="col mb-2">
                        <label class="form-label">Horas estimadas default</label>
                        <input type="number" step="0.01" class="form-control" id="templateDefaultEstimatedHours" value="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Projects.saveTemplate()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/projects.js"></script>
}
