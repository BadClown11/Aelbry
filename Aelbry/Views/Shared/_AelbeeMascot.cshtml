@{
    // Tamano del contenedor en rem; el SVG interno escala proporcionalmente.
    // Uso: <partial name="_AelbeeMascot" model="2.5" /> (por defecto 3rem).
    double sizeRem = Model is double d ? d : 3.0;
}
<div class="aelbry-mascot rounded-xl d-inline-flex align-items-center justify-content-center shadow-sm"
     style="width: @(sizeRem)rem; height: @(sizeRem)rem; background: linear-gradient(135deg, var(--aelbry-primary), #7c3aed); border-radius: 0.9rem;">
    <svg viewBox="0 0 48 48" style="width: @(sizeRem * 0.8)rem; height: @(sizeRem * 0.8)rem;" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 16L18 10M28 16L30 10" stroke="#FCD34D" stroke-width="2" stroke-linecap="round"/>
        <circle cx="18" cy="9" r="1.5" fill="#FCD34D"/>
        <circle cx="30" cy="9" r="1.5" fill="#FCD34D"/>
        <g class="aelbry-mascot-wings">
            <path d="M12 18C8 14 13 10 17 14C15 16 13 18 12 18Z" fill="#93C5FD" opacity="0.85"/>
            <path d="M36 18C40 14 35 10 31 14C33 16 35 18 36 18Z" fill="#93C5FD" opacity="0.85"/>
        </g>
        <rect x="13" y="16" width="22" height="18" rx="9" fill="#FCD34D"/>
        <rect x="18" y="16" width="3" height="18" fill="#1E293B"/>
        <rect x="27" y="16" width="3" height="18" fill="#1E293B"/>
        <rect x="15" y="19" width="18" height="8" rx="4" fill="#0F172A"/>
        <circle cx="20" cy="23" r="2.5" fill="#38BDF8"/>
        <circle cx="28" cy="23" r="2.5" fill="#38BDF8"/>
    </svg>
</div>
