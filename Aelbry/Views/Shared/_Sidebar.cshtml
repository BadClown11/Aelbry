<script>
    // ── Marcar enlace activo según URL actual ──
    function setActiveLink() {
        const path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.nav-item[data-view]').forEach(link => {
            const href = (link.getAttribute('href') || '').toLowerCase();
            // Coincidencia por controlador (primer segmento)
            const controller = href.split('/')[1];
            if (controller && path.includes(controller)) {
                link.classList.add('nav-item--active');
                const icon = link.querySelector('.nav-item__icon');
                if (icon) icon.classList.add('nav-item__icon--active');
            }
        });
    }
    setActiveLink();

    // ── Ocultar opciones que el usuario logueado no tiene permiso de usar ──
    // (la validacion real sigue viviendo en el servidor via [Authorize(Policy)]; esto
    // solo evita mostrar enlaces que terminarian en un 403).
    function filterByPermissions() {
        const permissions = window.Aelbry?.api?.getPermissions?.() ?? [];

        document.querySelectorAll('#sidebar-nav [data-permission], #btn-ai[data-permission]').forEach((el) => {
            if (!permissions.includes(el.getAttribute('data-permission'))) {
                el.style.display = 'none';
            }
        });

        // Ocultar tambien el titulo de una seccion si todos sus items quedaron ocultos.
        document.querySelectorAll('#sidebar-nav .sidebar__section-label').forEach((label) => {
            let sibling = label.nextElementSibling;
            let anyVisible = false;

            while (sibling && !sibling.classList.contains('sidebar__section-label')) {
                if (sibling.style.display !== 'none') anyVisible = true;
                sibling = sibling.nextElementSibling;
            }

            label.style.display = anyVisible ? '' : 'none';
        });
    }

    // api.js se carga mas abajo en el layout (despues de este partial), asi que hay que
    // esperar a que el documento termine de parsear/ejecutar todos los <script> antes de leerlo.
    document.addEventListener('DOMContentLoaded', filterByPermissions);

    // ── Colapsar sidebar ──
    let sidebarCollapsed = false;

    function toggleSidebar() {
        sidebarCollapsed = !sidebarCollapsed;
        const sidebar = document.getElementById('sidebar');
        const collapseIcon = document.getElementById('collapse-icon');

        sidebar.classList.toggle('sidebar--collapsed', sidebarCollapsed);
        collapseIcon.setAttribute('data-lucide', sidebarCollapsed ? 'chevron-right' : 'chevron-left');
        lucide.createIcons();

        // Notificar al layout padre si existe (para ajustar el main)
        window.dispatchEvent(new CustomEvent('sidebarToggle', { detail: { collapsed: sidebarCollapsed } }));
    }
</script>
