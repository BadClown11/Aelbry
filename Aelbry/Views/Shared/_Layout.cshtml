<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aelbry</title>
    <script>
        (function () {
            var t = localStorage.getItem('aelbry_theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@@latest"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="topbar">
        <div class="topbar__left">
            <a asp-controller="Home" asp-action="Index" class="topbar__logo">
                <div class="logo-mark">A</div>
                <span class="logo-name">Aelbry</span>
            </a>

            <div class="topbar__divider"></div>

            <div class="tenant-breadcrumb">
                <span class="tenant-breadcrumb__active" id="tenant-company">—</span>
                <span class="tenant-breadcrumb__sep">/</span>
                <span class="tenant-breadcrumb__item" id="tenant-dept">—</span>
                <span class="tenant-breadcrumb__sep">/</span>
                <span class="tenant-breadcrumb__item" id="tenant-team">—</span>
            </div>
        </div>

        <div class="topbar__search">
            <i data-lucide="search" class="search-icon"></i>
            <input type="text" class="search-input"
                   placeholder="Buscar proyectos, tareas, documentos… (Cmd + K)"
                   id="global-search" autocomplete="off" />
        </div>
        <div class="topbar__right">
            <div class="timer-pill">
                <span class="timer-pill__dot">
                    <span class="timer-pill__dot-ping"></span>
                    <span class="timer-pill__dot-core"></span>
                </span>
                <span class="timer-pill__time" id="live-timer">00:00:00</span>
                <span class="timer-pill__sep">|</span>
                <span class="timer-pill__task" id="timer-task-indicator">Sin tarea</span>
                <button class="timer-pill__toggle" onclick="toggleTimer()" title="Detener / reanudar">
                    <i data-lucide="square-play" id="timer-icon"></i>
                </button>
            </div>
            <div class="topbar__dropdown" id="notifDropdown">
                <button class="topbar__icon-btn" id="notificationBell" title="Notificaciones">
                    <i data-lucide="bell"></i>
                    <span class="badge-dot" id="notificationBadge" style="display:none"></span>
                </button>
                <div class="dropdown-panel" id="notificationPanel">
                    <div class="dropdown-panel__header">
                        <strong>Notificaciones</strong>
                        <button class="dropdown-panel__action"
                                onclick="Notifications.markAllAsRead()">
                            Marcar todas leídas
                        </button>
                    </div>
                    <ul class="notification-list" id="notificationList">
                        <li class="notification-list__empty">Sin notificaciones</li>
                    </ul>
                </div>
            </div>
            <button class="topbar__icon-btn" id="btn-theme" title="Cambiar tema">
                <i data-lucide="sun" id="icon-sun"></i>
                <i data-lucide="moon" id="icon-moon" style="display:none"></i>
            </button>

            <div class="topbar__divider"></div>
            <div class="topbar__profile" id="topbar-profile">
                <div class="avatar avatar--brand" id="user-avatar">--</div>
                <div class="topbar__profile-info">
                    <p class="topbar__profile-name" id="user-name">Cargando…</p>
                    <p class="topbar__profile-role" id="user-role"></p>
                </div>
                <i data-lucide="chevron-down" class="topbar__chevron"></i>
            </div>
            <button class="btn-logout" id="btnLogout">Cerrar sesión</button>
        </div>
    </header>
    <div class="app-body" id="app-body">

        <!-- Sidebar -->
        @await Html.PartialAsync("_Sidebar")
        <main class="workspace" id="main-workspace">
            <section class="project-header" id="project-header">
                <div class="project-header__inner">
                    <div class="project-header__meta">
                        <nav class="breadcrumb" aria-label="Ubicación">
                            <span class="breadcrumb__item">Proyectos</span>
                            <i data-lucide="chevron-right" class="breadcrumb__sep"></i>
                            <span class="breadcrumb__item breadcrumb__item--current"
                                  id="breadcrumb-project">@(ViewData["ProjectName"] ?? "—")</span>
                        </nav>
                        <div class="project-header__title-row">
                            <h1 class="project-title" id="project-title">
                                @(ViewData["ProjectName"] ?? "Selecciona un proyecto")
                            </h1>
                            <span class="status-badge status-badge--blue"
                                  id="project-status">
                                @(ViewData["ProjectStatus"] ?? "")
                            </span>
                        </div>
                    </div>

                    <div class="project-header__stats">
                        <!-- Progreso ponderado -->
                        <div class="progress-block">
                            <div class="progress-block__labels">
                                <span class="progress-block__label">Progreso Ponderado</span>
                                <span class="progress-block__value" id="header-progress-label">0%</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" id="header-progress-bar" style="width:0%"></div>
                            </div>
                        </div>

                        <!-- Horas -->
                        <div class="hours-block">
                            <p class="hours-block__label">Esfuerzo Estimado</p>
                            <p class="hours-block__value">
                                <span id="header-hours-estimated">—</span> hrs /
                                <span class="hours-block__accent" id="header-hours-logged">— registradas</span>
                            </p>
                        </div>
                        <div class="avatar-stack" id="team-avatars">
                        </div>
                    </div>
                </div>
            </section>
            <div class="workspace__content" id="workspace-content">
                @RenderBody()
            </div>
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>

    <script src="~/js/api.js" asp-append-version="true"></script>
    <script src="~/js/common.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        lucide.createIcons();
        const themeBtn  = document.getElementById('btn-theme');
        const iconSun   = document.getElementById('icon-sun');
        const iconMoon  = document.getElementById('icon-moon');

        function applyTheme(dark) {
            document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', dark ? 'dark' : 'light');
            localStorage.setItem('aelbry_theme', dark ? 'dark' : 'light');
            iconSun.style.display  = dark ? 'none' : '';
            iconMoon.style.display = dark ? ''     : 'none';
        }

        applyTheme(localStorage.getItem('aelbry_theme') === 'dark');

        themeBtn?.addEventListener('click', () => {
            applyTheme(document.documentElement.getAttribute('data-theme') !== 'dark');
        });

        let _timerRunning = false;
        let _elapsed = 0;

        setInterval(() => {
            if (!_timerRunning) return;
            _elapsed++;
            const h = String(Math.floor(_elapsed / 3600)).padStart(2, '0');
            const m = String(Math.floor((_elapsed % 3600) / 60)).padStart(2, '0');
            const s = String(_elapsed % 60).padStart(2, '0');
            document.getElementById('live-timer').textContent = `${h}:${m}:${s}`;
        }, 1000);

        function toggleTimer() {
            _timerRunning = !_timerRunning;
            const icon = document.getElementById('timer-icon');
            icon.setAttribute('data-lucide', _timerRunning ? 'square-play' : 'circle-play');
            icon.classList.toggle('timer-pill__toggle--paused', !_timerRunning);
            lucide.createIcons();
        }
        window.AelbryTimer = {
            start(taskLabel) {
                _elapsed = 0;
                _timerRunning = true;
                document.getElementById('timer-task-indicator').textContent = taskLabel || 'Sin tarea';
                document.getElementById('timer-icon').setAttribute('data-lucide', 'square-play');
                lucide.createIcons();
            },
            stop() { _timerRunning = false; }
        };
        document.getElementById('notificationBell')?.addEventListener('click', (e) => {
            e.stopPropagation();
            document.getElementById('notificationPanel').classList.toggle('is-open');
        });
        document.addEventListener('click', () => {
            document.getElementById('notificationPanel')?.classList.remove('is-open');
        });

        document.getElementById('btnLogout')?.addEventListener('click', () => {
            Aelbry.api.logout().finally(() => window.location.href = '/Auth/Login');
        });

        window.addEventListener('sidebarToggle', (e) => {
            const main = document.getElementById('main-workspace');
            if (main) main.classList.toggle('workspace--sidebar-collapsed', e.detail.collapsed);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
