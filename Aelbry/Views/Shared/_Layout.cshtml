<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aelbry</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-controller="Company" asp-action="Index">Aelbry</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Index">Empresas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Index">Usuarios</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Project" asp-action="Index">Proyectos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Activity" asp-action="Index">Actividades</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="AiAssistant" asp-action="Index">Asistente IA</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Kanban" asp-action="Index">Kanban</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Gantt" asp-action="Index">Gantt</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="CalendarView" asp-action="Index">Calendario</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="TimeEntry" asp-action="Index">Mis Horas</a></li>
                </ul>
                <button id="btnLogout" class="btn btn-outline-light btn-sm">Cerrar sesion</button>
            </div>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/api.js"></script>
    <script>
        document.getElementById('btnLogout')?.addEventListener('click', () => {
            Aelbry.api.logout().finally(() => window.location.href = '/Auth/Login');
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
