<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aelbry</title>
    <script>
        (function () {
            var theme = localStorage.getItem('aelbry_theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/common.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark aelbry-navbar mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Company" asp-action="Index">Aelbry</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto flex-wrap">
                    <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Index">Empresas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Index">Usuarios</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Project" asp-action="Index">Proyectos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Activity" asp-action="Index">Actividades</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="AiAssistant" asp-action="Index">Asistente IA</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Kanban" asp-action="Index">Kanban</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Gantt" asp-action="Index">Gantt</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="CalendarView" asp-action="Index">Calendario</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="TimeEntry" asp-action="Index">Mis Horas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index">Chat</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Document" asp-action="Index">Documentos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="AutomationRule" asp-action="Index">Automatizaciones</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Report" asp-action="Index">Reportes</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="AuditLog" asp-action="Index">Auditoria</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <div class="dropdown">
                        <button id="notificationBell" class="btn btn-sm rounded-circle position-relative" title="Notificaciones" style="width: 2.25rem; height: 2.25rem;" data-bs-toggle="dropdown">
                            🔔
                            <span id="notificationBadge" class="badge rounded-pill text-bg-danger position-absolute top-0 start-100 translate-middle d-none">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-0" style="width: 320px; max-height: 420px; overflow-y: auto;">
                            <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                                <strong class="small">Notificaciones</strong>
                                <button class="btn btn-sm btn-link p-0" onclick="Notifications.markAllAsRead()">Marcar todas leidas</button>
                            </div>
                            <ul class="list-group list-group-flush" id="notificationList">
                                <li class="list-group-item small text-muted">Sin notificaciones</li>
                            </ul>
                        </div>
                    </div>
                    <button id="themeToggle" class="btn btn-sm rounded-circle" title="Cambiar tema" style="width: 2.25rem; height: 2.25rem;">
                        <span id="themeToggleIcon">🌙</span>
                    </button>
                    <button id="btnLogout" class="btn btn-outline-light btn-sm">Cerrar sesion</button>
                </div>
            </div>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/api.js"></script>
    <script src="~/js/common.js"></script>
    <script src="~/js/notifications.js"></script>
    <script>
        document.getElementById('btnLogout')?.addEventListener('click', () => {
            Aelbry.api.logout().finally(() => window.location.href = '/Auth/Login');
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
