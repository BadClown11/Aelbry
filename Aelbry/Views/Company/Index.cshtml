@{
    ViewData["Title"] = "Empresas";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Empresas</h4>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#companyModal" onclick="Companies.openCreate()">
        Nueva empresa
    </button>
</div>

<div class="card">
    <div class="card-body">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>RFC / Tax ID</th>
                    <th>Zona horaria</th>
                    <th>Activa</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="companyRows"></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="companyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Empresa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="companyId" />
                <div class="mb-2">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" id="companyName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">RFC / Tax ID</label>
                    <input class="form-control" id="companyTaxId" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Zona horaria</label>
                    <input class="form-control" id="companyTimeZone" value="UTC" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" onclick="Companies.save()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/companies.js"></script>
}
