@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesion";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aelbry</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-primary-subtle">
    <div class="card auth-card p-4">
        <h3 class="mb-3 text-center">Aelbry</h3>
        <p class="text-muted text-center mb-4">Gestion de Proyectos Empresarial</p>

        <div id="loginError" class="alert alert-danger d-none"></div>

        <form id="loginForm">
            <div class="mb-3">
                <label class="form-label">Correo electronico</label>
                <input type="email" class="form-control" id="email" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Contrasena</label>
                <input type="password" class="form-control" id="password" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Ingresar</button>
        </form>
    </div>

    <script src="~/js/api.js"></script>
    <script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const errorBox = document.getElementById('loginError');
            errorBox.classList.add('d-none');

            const result = await Aelbry.api.login(email, password);
            if (result.result === 'OK') {
                window.location.href = '/Company/Index';
            } else {
                errorBox.textContent = result.result;
                errorBox.classList.remove('d-none');
            }
        });
    </script>
</body>
</html>
